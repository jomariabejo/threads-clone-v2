{
  "name": "connectly-frontend",
  "description": "Connectly - a Threads-style social app frontend, backed by the Connectly REST API",
  "author": "BishopZ",
  "private": true,
  "version": "1.3.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bishopz/2026-boilerplate"
  },
  "type": "module",
  "scripts": {
    "dev": "nodemon -w src/server -x tsx --env-file .env src/server/main.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "gen:api-types": "openapi-typescript ./docs/openapi.yaml -o ./src/generated/api/openapi.generated.ts",
    "check:i18n": "node ./scripts/check-i18n-keys.mjs",
    "preview": "vite preview",
    "start": "NODE_ENV=production tsx src/server/main.ts",
    "type-check": "tsc --noEmit",
    "test": "npm run lint && npm run type-check && npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:open": "playwright test --ui"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@fontsource/inter": "^5.2.8",
    "@reduxjs/toolkit": "2.11.2",
    "@tanstack/react-query": "^5.101.0",
    "@tiptap/extension-link": "^3.26.0",
    "@tiptap/extensions": "^3.26.0",
    "@tiptap/html": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "axios": "^1.17.0",
    "express": "5.2.1",
    "framer-motion": "^12.38.0",
    "helmet": "^8.1.0",
    "next-themes": "0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-error-boundary": "6.1.1",
    "react-icons": "^5.6.0",
    "react-intl": "10.1.8",
    "react-redux": "9.2.0",
    "react-router": "^7.15.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite-express": "0.22.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/ejs": "3.1.5",
    "@types/express": "5.0.6",
    "@types/node": "^25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-dom": "^5.7.7",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-react-x": "^5.7.7",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "nodemon": "3.1.14",
    "openapi-typescript": "^7.13.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=24.13.1",
    "npm": ">=11.10.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
